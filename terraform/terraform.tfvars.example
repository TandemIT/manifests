# Proxmox Connection
proxmox_api_url          = "https://<YOUR_PROXMOX_HOST>:8006/api2/json"
proxmox_api_token_id     = "root@pam!terraform"
proxmox_api_token_secret = "YOUR_TOKEN_SECRET_HERE"

# SSH Key
ssh_public_key = "ssh-ed25519 YOUR_PUBLIC_KEY_HERE"

# Proxmox Settings
# NOTE: the template must have qemu-guest-agent preinstalled (agent = 1 in
# main.tf makes Terraform wait for it before finishing the apply).
proxmox_node = "proxmox"
template_id  = "ubuntu-24.04-cloud-tpl"
vm_id_start  = 200
storage      = "local-zfs"
bridge       = "vmbr0"
gateway      = "172.16.69.1"
nameserver   = "172.16.69.1"
searchdomain = "local"

# Control Plane Configuration (3 nodes for etcd quorum + kube-vip HA)
control_plane_count     = 3
control_plane_cpu       = 2
control_plane_memory    = 4096
control_plane_disk_size = "15G"
control_plane_ip_start  = "172.16.69.100"

# Worker Configuration
worker_count     = 3
worker_cpu       = 1
worker_memory    = 2048
worker_disk_size = "10G"
worker_ip_start  = "172.16.69.150"

# K3s Configuration
# The manifests in this repo are pinned/tested against v1.32.3+k3s1.
k3s_version = "v1.32.3+k3s1"

# Control-plane VIP (kube-vip). Keep outside the node ranges and the
# MetalLB pool (platform/metallb/ipaddresspool.yaml, default .60).
vip = "172.16.69.50"

# Where the nodes + Argo CD pull the manifests from. Local commits must be
# pushed here before deploying.
manifests_repo     = "https://github.com/TandemIT/manifests.git"
manifests_revision = "master"

# Gitea OIDC login providers (optional, any number). Create the OAuth2
# provider/application for each in your identity provider (e.g. Authentik)
# yourself, then add an entry below, keyed by a short slug - this repo does
# not create or manage identity-provider resources. Leave empty ({}) to
# skip OIDC (scripts/06-seal-secrets.sh will prompt interactively instead).
gitea_oidc_providers = {
  # authentik = {
  #   display_name  = "Authentik"
  #   client_id     = "YOUR_CLIENT_ID"
  #   client_secret = "YOUR_CLIENT_SECRET"
  #   discovery_url = "https://auth.open-ict.hu/application/o/gitea/.well-known/openid-configuration"
  #   icon_url      = "https://auth.open-ict.hu/static/dist/assets/icons/icon.png"
  # }
  # keycloak = {
  #   display_name  = "Keycloak"
  #   client_id     = "YOUR_CLIENT_ID"
  #   client_secret = "YOUR_CLIENT_SECRET"
  #   discovery_url = "https://keycloak.example.com/realms/main/.well-known/openid-configuration"
  # }
}

# Gitea LDAP login providers (optional, any number) - same idea as OIDC
# above. Point at an existing LDAP/AD server, or an Authentik LDAP outpost
# if you set one up; this repo does not create or manage either.
gitea_ldap_providers = {
  # authentik = {
  #   display_name     = "Authentik LDAP"
  #   host             = "ldap.open-ict.hu"
  #   port             = 636
  #   security_protocol = "LDAPS"
  #   bind_dn          = "cn=gitea,ou=service-accounts,dc=open-ict,dc=hu"
  #   bind_password    = "YOUR_BIND_PASSWORD"
  #   user_search_base = "ou=users,dc=open-ict,dc=hu"
  #   user_filter      = "(&(objectClass=user)(memberOf=cn=gitea-users,ou=groups,dc=open-ict,dc=hu)(uid=%s))"
  #   admin_filter     = "(memberOf=cn=gitea-admins,ou=groups,dc=open-ict,dc=hu)"
  # }
}
